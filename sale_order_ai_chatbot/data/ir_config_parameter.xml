<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Groq API Key (empty by default - user must configure) -->
        <record id="param_groq_api_key" model="ir.config_parameter">
            <field name="key">sale_order_ai_chatbot.groq_api_key</field>
            <field name="value"></field>
        </record>

        <!-- Default Groq Chat Model -->
        <record id="param_groq_model" model="ir.config_parameter">
            <field name="key">sale_order_ai_chatbot.groq_model</field>
            <field name="value">llama-3.3-70b-versatile</field>
        </record>

        <!-- Default Groq Vision Model -->
        <record id="param_groq_vision_model" model="ir.config_parameter">
            <field name="key">sale_order_ai_chatbot.groq_vision_model</field>
            <field name="value">qwen/qwen3.6-27b</field>
        </record>

        <!-- Default Max Tokens -->
        <record id="param_groq_max_tokens" model="ir.config_parameter">
            <field name="key">sale_order_ai_chatbot.groq_max_tokens</field>
            <field name="value">4096</field>
        </record>

        <!-- Session sequence -->
        <record id="seq_sale_chatbot_session" model="ir.sequence">
            <field name="name">AI Sales Chat Session</field>
            <field name="code">sale.chatbot.session</field>
            <field name="prefix">CHAT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
