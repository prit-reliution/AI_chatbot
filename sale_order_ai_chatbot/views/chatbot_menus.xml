<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- AI Sales Chatbot Root App Menu -->
    <menuitem
        id="menu_sale_chatbot_root"
        name="AI Sales Chatbot"
        web_icon="sale_order_ai_chatbot,static/description/icon.png"
        sequence="25"
    />

    <!-- AI Sales Assistant Menu Item (opens the chatbot client action) -->
    <menuitem
        id="menu_sale_chatbot_new"
        name="AI Sales Assistant"
        parent="menu_sale_chatbot_root"
        action="action_chatbot_client"
        sequence="10"
    />

    <!-- AI Chat History Menu Item (lists chatbot sessions) -->
    <menuitem
        id="menu_sale_chatbot_history"
        name="AI Chat History"
        parent="menu_sale_chatbot_root"
        action="action_chatbot_session_list"
        sequence="20"
    />

    <!-- AI Chatbot Settings (links to settings) -->
    <menuitem
        id="menu_sale_chatbot_settings"
        name="AI Chatbot Settings"
        parent="menu_sale_chatbot_root"
        action="action_sale_chatbot_config_settings"
        sequence="30"
    />

    <!-- Actions to open specific categories directly in form view -->
    <record id="action_alias_category_blind_direct" model="ir.actions.act_window">
        <field name="name">Blind Lookup Aliases</field>
        <field name="res_model">alias.category</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="alias.alias_category_blind" />
        <field name="target">current</field>
    </record>

    <record id="action_alias_category_fabric_direct" model="ir.actions.act_window">
        <field name="name">Fabric Lookup Aliases</field>
        <field name="res_model">alias.category</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="alias.alias_category_fabric" />
        <field name="target">current</field>
    </record>

    <record id="action_alias_category_track_direct" model="ir.actions.act_window">
        <field name="name">Track Lookup Aliases</field>
        <field name="res_model">alias.category</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="alias.alias_category_track" />
        <field name="target">current</field>
    </record>

    <!-- Parent Menu for Lookup Aliases -->
    <menuitem
        id="menu_sale_chatbot_alias_root"
        name="Lookup Aliases"
        parent="menu_sale_chatbot_root"
        action="alias.action_alias_category_list"
        sequence="25"
    />

    <!-- Submenus representing the three categories/tabs -->
    <menuitem
        id="menu_sale_chatbot_alias_blind"
        name="Blind"
        parent="menu_sale_chatbot_alias_root"
        action="action_alias_category_blind_direct"
        sequence="10"
    />

    <menuitem
        id="menu_sale_chatbot_alias_fabric"
        name="Fabric"
        parent="menu_sale_chatbot_alias_root"
        action="action_alias_category_fabric_direct"
        sequence="20"
    />

    <menuitem
        id="menu_sale_chatbot_alias_track"
        name="Track"
        parent="menu_sale_chatbot_alias_root"
        action="action_alias_category_track_direct"
        sequence="30"
    />

</odoo>