<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">sale.chatbot.res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="AI Sales Bot" data-string="AI Sales Bot" name="sale_order_ai_chatbot">
                    <block title="Groq API Configuration" name="groq_config_container">
                        <setting id="groq_api_key_setting" string="Groq API Key" help="Get your API key from console.groq.com/keys">
                            <field name="groq_api_key" password="True" placeholder="gsk_..."/>
                        </setting>
                        <setting id="groq_model_setting" string="Groq Chat Model" help="Model for natural language understanding and order extraction">
                            <field name="groq_model" placeholder="llama-3.3-70b-versatile"/>
                        </setting>
                        <setting id="groq_vision_model_setting" string="Groq Vision Model" help="Model for image OCR and document understanding (scanned PDFs, screenshots)">
                            <field name="groq_vision_model" placeholder="qwen/qwen3.6-27b"/>
                        </setting>
                        <setting id="groq_max_tokens_setting" string="Max Response Tokens" help="Maximum tokens in AI responses (default: 4096)">
                            <field name="groq_max_tokens"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_sale_chatbot_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'sale_order_ai_chatbot', 'bin_size': False}</field>
    </record>
</odoo>
