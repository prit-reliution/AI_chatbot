<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_alias_category_tree" model="ir.ui.view">
        <field name="name">alias.category.tree</field>
        <field name="model">alias.category</field>
        <field name="arch" type="xml">
            <tree string="Lookup Alias Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_alias_category_kanban" model="ir.ui.view">
        <field name="name">alias.category.kanban</field>
        <field name="model">alias.category</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" create="false" destroy="false">
                <field name="id"/>
                <field name="name"/>
                <field name="type"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record" style="border-left: 4px solid var(--bot-accent, #6c63ff); border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); padding: 16px;">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title" style="font-size: 18px; color: #4b5563;">
                                    <t t-esc="record.name.value"/>
                                </strong>
                                <div style="margin-top: 8px; font-size: 13px; color: #6b7280;">
                                    <span>Type: </span>
                                    <strong style="text-transform: capitalize;"><t t-esc="record.type.value"/></strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_alias_category_form" model="ir.ui.view">
        <field name="name">alias.category.form</field>
        <field name="model">alias.category</field>
        <field name="arch" type="xml">
            <form string="Lookup Alias Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Category Name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type" readonly="1"/>
                        </group>
                        <group>
                            <field name="allowed_product_category_ids" widget="many2many_tags" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Aliases Setup" name="aliases_setup">
                            <field name="line_ids" mode="tree">
                                <tree editable="bottom" string="Lookup Aliases Grid">
                                    <field name="allowed_product_category_ids" invisible="1"/>
                                    <field name="alias_name" placeholder="e.g. KK-Fabric"/>
                                    <field name="product_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('categ_id', 'in', allowed_product_category_ids)]" placeholder="Select product(s)..."/>
                                    <field name="partner_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Select customer(s) (Leave blank for global)..."/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_alias_category_list" model="ir.actions.act_window">
        <field name="name">Lookup Aliases</field>
        <field name="res_model">alias.category</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- Menuitem -->
    <menuitem
        id="menu_alias_category_sales_config"
        name="B2B Lookup Aliases"
        parent="sale.menu_sale_config"
        action="action_alias_category_list"
        sequence="25"
    />
</odoo>
